# === ACP Agent Credentials ===
# Get these from your Virtuals dashboard
WHITELISTED_WALLET_PRIVATE_KEY=your_private_key_here
SELLER_AGENT_WALLET_ADDRESS=0xYourAgentWalletAddress
SELLER_ENTITY_ID=1

# === Paths ===
# Path to the alpha signals backend scripts directory
PYTHON_SCRIPTS_PATH=/path/to/alpha-signals-backend/scripts

# Path to tracker symbol JSON files (one per tracked symbol)
TRACKER_SYMBOL_DIR=/path/to/tracker/symbol

# Path to hl-trader state directory (context files)
HL_TRADER_STATE_DIR=/path/to/hl-trader/state

# === Resource Server ===
RESOURCE_HOST=127.0.0.1
RESOURCE_PORT=18791
RESOURCE_MAX_CONTEXT_AGE_SEC=900
RESOURCE_MAX_CONCURRENT=10

# === Optional Tuning ===
BEST_TRADE_TIMEOUT_SEC=120
